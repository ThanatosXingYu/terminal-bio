{
  "name": "terminal-bio",
  "private": true,
  "version": "1.3.1",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=18.17",
    "npm": ">=10"
  },
  "description": "macOS 风格交互式终端个人主页模板",
  "author": "Thanatos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThanatosXingYu/terminal-bio.git"
  },
  "scripts": {
    "dev": "node server/index.mjs --dev",
    "build": "tsc && vite build --config tooling/vite.config.ts",
    "start": "node server/index.mjs",
    "preview": "node server/index.mjs",
    "test:server": "node --test server/server.test.mjs",
    "test:once": "node --test server/server.test.mjs && vitest run --config tooling/vite.config.ts",
    "test": "vitest --config tooling/vite.config.ts",
    "coverage": "vitest run --coverage --config tooling/vite.config.ts",
    "prepare": "husky install",
    "lint": "eslint src server terminal.config.mjs tooling/vite.config.ts --ext .ts,.tsx,.mjs",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^5.3.10",
    "styled-normalize": "^8.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/lodash": "^4.14.194",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "@types/styled-components": "^5.1.26",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@typescript-eslint/eslint-plugin": "^5.59.6",
    "@typescript-eslint/parser": "^5.59.6",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-c8": "^0.31.1",
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-markdown": "^3.0.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "jsdom": "^22.0.0",
    "lint-staged": "^13.2.2",
    "prettier": "^2.8.8",
    "typescript": "^5.0.4",
    "vite": "^4.5.3",
    "vite-plugin-pwa": "^0.14.7",
    "vitest": "^0.31.1"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": [
      "eslint",
      "prettier --write"
    ],
    "*.{json,md,html}": "prettier --write"
  }
}
